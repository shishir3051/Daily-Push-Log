# Daily Push Log — backend environment variables
# Copy this file to .env and fill in your real values. Never commit .env to Git.

# MongoDB connection string
MONGODB_URI=

# Gemini AI API key (for AI task summarization)
GEMINI_API_KEY=

# Gemini model to use. Defaults to gemini-flash-latest if unset.
# If you get a 404 "no longer available" error, list usable models via:
#   GET https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY
GEMINI_MODEL=

# ── nProject (OpenProject) integration ──────────────────────────────────────
# Base URL of your OpenProject instance (no trailing slash)
NPROJECT_URL=https://nproject

# OpenProject login credentials for API Basic Auth
NPROJECT_USERNAME=
NPROJECT_PASSWORD=

# Set to true if your nProject uses a self-signed / internal TLS certificate
NPROJECT_INSECURE=true

# Work-package type ID to use when creating tasks (1 = Task in most installs)
# Check available types: GET /api/v3/types
NPROJECT_TYPE_ID=1

# Optional: filter git commits by author name (leave empty to use OS username, 'all' for all authors)
GIT_AUTHOR_FILTER=
